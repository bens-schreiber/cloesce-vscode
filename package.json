{
  "name": "cloesce",
  "displayName": "Cloesce",
  "description": "Syntax highlighting for the Cloesce schema language",
  "version": "0.1.0",
  "publisher": "cloesce",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/bens-schreiber/cloesce-vscode"
  },
  "contributes": {
    "languages": [
      {
        "id": "cloesce",
        "aliases": [
          "Cloesce",
          "cloesce"
        ],
        "extensions": [
          ".cloesce",
          ".clo"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cloesce",
        "scopeName": "source.cloesce",
        "path": "./syntaxes/cloesce.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "http.verb.get.cloesce",
            "settings": { "foreground": "#61AFEF", "fontStyle": "bold" }
          },
          {
            "scope": "http.verb.post.cloesce",
            "settings": { "foreground": "#98C379", "fontStyle": "bold" }
          },
          {
            "scope": "http.verb.put.cloesce",
            "settings": { "foreground": "#E5C07B", "fontStyle": "bold" }
          },
          {
            "scope": "http.verb.patch.cloesce",
            "settings": { "foreground": "#D19A66", "fontStyle": "bold" }
          },
          {
            "scope": "http.verb.delete.cloesce",
            "settings": { "foreground": "#E06C75", "fontStyle": "bold" }
          },
          {
            "scope": "punctuation.separator.arrow.cloesce",
            "settings": { "foreground": "#ABB2BF" }
          }
        ]
      }
    }
  }
}
